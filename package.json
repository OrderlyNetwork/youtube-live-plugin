{
  "name": "@orderly.network/youtube-live-plugin",
  "version": "0.1.1",
  "description": "Orderly SDK plugin — youtube-live",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup && pnpm run build:css && cp -r src/i18n/locales dist/locales",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build",
    "build:css": "tailwindcss build -i src/tailwind.css -o dist/styles.css --minify",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@orderly.network/hooks": ">=3.0.0",
    "@orderly.network/i18n": ">=3.0.0",
    "@orderly.network/plugin-core": ">=3.0.0",
    "@orderly.network/types": ">=3.0.0",
    "@orderly.network/ui": ">=3.0.0",
    "@orderly.network/utils": ">=3.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@orderly.network/core": ">=3.0.0",
    "@orderly.network/react-app": ">=3.0.0",
    "@orderly.network/trading": ">=3.0.0",
    "@storybook/react": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@storybook/react-webpack5": "^10.4.0",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.17",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.4.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.6",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6",
    "vite": "^7.3.3",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@orderly.network/ui-scaffold": ">=3.0.0",
    "@orderly.network/wallet-connector-privy": ">=3.0.0",
    "@solana-mobile/wallet-adapter-mobile": "^2.2.6",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-wallets": "^0.19.38"
  }
}
